# =============================================================================
# WaterX SDK — local configuration (NO secrets in git)
# =============================================================================
#
# Recommended workflow:
#   1. `pnpm env:init`   → copies this file to `.env.local` (gitignored, chmod 600 on Unix)
#   2. Edit `.env.local` with real values (especially private keys).
#
# Precedence:
#   • Variables already exported in your shell always win.
#   • Then `.env` is applied (dotenv: does not override shell).
#   • Then `.env.local` fills keys that were NOT in the shell when Node started — so it can
#     override values from `.env` for machine-specific secrets without committing them.
#
# Docs: `test/README.md`, `test/integration/setup.ts`
# =============================================================================

# --- Integration trader (on-chain tests: `pnpm test:integration`) --------------

# Bech32 secret (`suiprivkey...`). Prefer `.env.local` over committing `.env`.
# Alternative: repo-root `.integration-trader.keystore` (also gitignored); env wins if both exist.
# WATERX_INTEGRATION_PRIVATE_KEY=suiprivkey1qxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: wxa account UUID when the signer owns several (`getAccountsByOwner`).
# WATERX_INTEGRATION_ACCOUNT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Optional: choose key when `.integration-trader.keystore` has multiple entries.
# WATERX_INTEGRATION_ADDRESS=0xaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa

# Optional: destructive close-one test (`trader-close-position`) — see test file.
# WATERX_INTEGRATION_CLOSE_ONE_POSITION=1

# Optional: pin ticker / position id for close integration helpers.
# WATERX_INTEGRATION_CLOSE_BASE=BTCUSD
# WATERX_INTEGRATION_POSITION_ID=42
# WATERX_INTEGRATION_BTC_POSITION_ID=42

# Optional: integration cooldown retry floor (ms); see test/integration/setup.ts.
# WATERX_INTEGRATION_TRADING_STEP_MS=3000

# Optional: subset of lifecycle bases (`pnpm test:integration:lifecycle`).
# WATERX_INTEGRATION_BASES=BTC,ETH

# Optional: Vitest parallel forks for integration (default 1).
# WATERX_INTEGRATION_MAX_FORKS=2

# Optional: explicit integration network if not passing `--testnet` / `--mainnet` on CLI.
# WATERX_INTEGRATION_NETWORK=testnet

# Optional: gas budget cap (mist) for all integration txs (defaults ~0.01–0.02 SUI per flow).
# WATERX_INTEGRATION_GAS_BUDGET=10000000

# Optional: pre-skip when wallet SUI is below this (mist). Default: off — tests try on-chain first.
# WATERX_INTEGRATION_MIN_SUI_MIST=50000000

# Opt-in lifecycle smoke path — see trader-position-lifecycle.test.ts.
# WATERX_INTEGRATION_APPROX_PRICE_CHAIN=1

# --- Simulate / e2e (`pnpm test:e2e`, `scripts/run-e2e.ts`) --------------------

# WATERX_E2E_NETWORK=testnet

# Local only: seed testnet slots before e2e simulate (not run by `pnpm test:e2e` / CI).
# pnpm test:e2e:preflight
# Sets WATERX_E2E_WXA_ACCOUNT_ID when unset. Optional: WATERX_E2E_PREFLIGHT_CREDIT=0, WATERX_E2E_PREFLIGHT_REDEEM=0

# Optional: simulate (e2e) gas budget cap in mist (default 30_000_000).
# WATERX_E2E_SIMULATE_GAS_BUDGET=30000000

# Optional full-node / paid RPC (shared by simulate + integration client init paths).
# WATERX_E2E_GRPC_URL=https://...

# WATERX_E2E_GRPC_RETRY_ATTEMPTS=8

# Parallel simulate **files** — only raise with tolerant RPC (see vitest.config.ts).
# WATERX_E2E_MAX_FORKS=3

# Discovery gates — see test/helpers/e2e/discover-on-chain-position.ts.
# WATERX_E2E_PROBE_MIN_ACCOUNT_USDC=20000000
# WATERX_E2E_DISCOVERY_MAX_LEVERAGE_UTIL_PCT=...
# WATERX_E2E_DISCOVERY_LAST_TIER_LEVERAGE_PCT=...
# WATERX_E2E_DISCOVERY_MAX_PAGES=...
# WATERX_E2E_DISCOVERY_MIN_POSITION_SIZE=...
# WATERX_E2E_DISCOVERY_PROBE_PARALLEL=1
# WATERX_E2E_DISCOVERY_PROBE_CONCURRENCY=...
# WATERX_E2E_DISCOVERY_MAX_USDC_COIN_PROBES=...
# Optional wxa account for simulate discovery (overrides built-in testnet canonical account in code).
# WATERX_E2E_WXA_ACCOUNT_ID=0x...
# Optional wxa owner when resolving account → owner (default: integration signer or canonical owner in code).
# WATERX_E2E_WXA_OWNER=0x...
# WATERX_E2E_DISABLE_CANONICAL_WXA=1
# WATERX_E2E_CANONICAL_WXA_ACCOUNT_ID=0x...
# WATERX_E2E_CANONICAL_WXA_OWNER=0x...
# WATERX_E2E_WALLET_USDC_OWNER=0x...
# WATERX_E2E_WLP_REDEEM_OWNER=0x...

# Dump simulate successes — scratch helper / debugging.
# WATERX_E2E_SIMULATE_SUCCESS_DUMP=1

# Hermes REST (oracle price VAAs). Testnet SDK default: hermes-beta.pyth.network (PYTH_DEFAULTS.TESTNET;
# matches testnet feed ids in waterx-config — prod Hermes returns 404 for those ids).
# SDK fetchPriceFeedsUpdateData() is a single request; non-2xx throws (no retry / failover in SDK).
# E2e simulate skips Hermes 404/429/5xx via skipHermesIfFeedUnavailable (see test/README.md).
# CI uses the same beta default (see `.github/workflows/ci.yml`). Override via waterx-config `pyth` only.

# --- Misc -----------------------------------------------------------------------

# Canonical config URL. REQUIRED unless an explicit `configUrl` opt is passed —
# `loadConfig` has no built-in default and throws when neither is set. Fetched
# **as-is**: no `<network>.json` / git ref is appended. Precedence: `configUrl` opt
# → WATERX_CONFIG_URL.
# WATERX_CONFIG_URL=https://raw.githubusercontent.com/WaterXProtocol/waterx-config/main/testnet.json

# =============================================================================
# Prediction line (`tests/`, `pnpm test:e2e:predict`, `pnpm test:integration:predict`)
# =============================================================================
# Prediction e2e fetches WaterXProtocol/waterx-config and discovers on-chain — these are
# all OPTIONAL (not required for `pnpm test:e2e:predict` or CI).

# --- Optional: prediction client/discovery overrides ---
# E2E_CONFIG_URL=https://raw.githubusercontent.com/WaterXProtocol/waterx-config/main/testnet.json
# E2E_GRPC_URL=https://fullnode.testnet.sui.io:443
# E2E_SETTLEMENT_ASSET=USD

# --- Optional: pin prediction fixtures instead of chain discovery ---
# E2E_ACCOUNT_ID=0x...
# E2E_ACCOUNT_OWNER=0x...   # simulate sender for account-scoped PTBs (no private key needed)
# E2E_ORDER_ID=1
# E2E_POSITION_ID=1
# E2E_MARKET_ID=0x...
# E2E_MARKET_KEY=1
# E2E_USD_COIN_OBJECT_ID=0x...

# --- Prediction testnet seed + integration (local only; `pnpm test:integration:predict`) ---
# SUI_PRIVATE_KEY=suiprivkey1...   # or 0x + 64 hex (32-byte seed) — used by seed script & integration
# E2E_KEEPER_PRIVATE_KEY=...       # Optional: keeper key for fillOrder in prediction seed
# SEED_DEPOSIT_AMOUNT=1000000      # Seed/integration deposit in base units (default 1_000_000)

# --- Prediction HTTP API smoke (`pnpm test:api:local` / `test:api:staging`) ---
# E2E_API_ENV=staging|local        # default staging → api-waterx.up.railway.app; local → :3003
# E2E_API_ADDRESS=0x...            # wallet for GET /predict/bets/me* (?address=; backend #601)
# E2E_API_JWT=...                  # optional — suiAddress claim used when E2E_API_ADDRESS unset
# E2E_API_CROSSCHECK=1             # catalog place+fill → poll bets/me (pnpm test:integration:predict:crosscheck)
# E2E_API_CROSSCHECK_STRICT=1      # fail on supplemental field-audit mismatches (default: log only)
# E2E_API_CROSSCHECK_BROKER_WAIT_MS=30000   # default 30s (bypass broker fill is usually fast)
# E2E_API_CROSSCHECK_BETS_POLL_MS=60000     # default 60s indexer poll; raise if staging CH lags
# E2E_API_CROSSCHECK_BETS_POLL_INTERVAL_MS=2000
# E2E_API_TX_BUILD=1               # POST /predict/bets/place → txBytes closed loop
# E2E_API_PLACE_ACCOUNT_ID=0x...   # wxa accountId for place tx-build
# E2E_API_PLACE_SENDER=0x...       # wallet sender for place tx-build

# --- Staging catalog place amount (scripts + integration crosscheck/headless) ---
# E2E_STAGING_BET_USD=1.11         # default; parallel slots: 2.22, 3.33 (slot × $1.11)
# E2E_STAGING_MAX_SPEND=1030000    # override in settlement base units ($1.03 = 1030000)
# E2E_PLACE_EXPIRY_MS=90000        # order expiry window (~90s)
# E2E_PLACE_PRICE_CAP_BPS=2701     # override cap (default: oddsCents + 1 bps)

# --- Staging catalog fill policy (default: backend broker only — no local fillOrder) ---
# E2E_CATALOG_KEEPER_FALLBACK=1       # opt-in local keeper fillOrder when broker is down

# --- Staging probes (local only; need SUI_PRIVATE_KEY + funded wxa) ---
# pnpm predict:place-all-markets | predict:place-dry-run | predict:refund-probe | predict:broker-matrix
# E2E_PLACE_ALL_DRY_RUN=1
# E2E_PLACE_ALL_LIMIT=5
# E2E_PLACE_ALL_ONE_SIDE=1
# E2E_PLACE_ALL_PLACE_ONLY=1       # place only — predict:place-and-watch
# E2E_PLACE_ALL_BROKER_ONLY=1
# E2E_PLACE_ALL_BROKER_WAIT_MS=45000
# E2E_PLACE_ALL_CONCURRENCY=3      # parallel broker wait; place txs stay sequential
# E2E_PLACE_ALL_DELAY_MS=1500
# E2E_PLACE_ALL_SEGMENTS=sport,crypto
# E2E_PLACE_ALL_CRYPTO_EPOCHS=1
# E2E_PLACE_ALL_CRYPTO_EPOCH_LIMIT=3
# E2E_CATALOG_REFUND=1             # vitest: test:integration:predict:refund
# E2E_CATALOG_REFUND_WAIT_MS=90000
# E2E_BROKER_MATRIX=1              # vitest: test:integration:predict:broker-matrix
# E2E_BROKER_MATRIX_SCENARIOS=fillable-normal,tight-701
# E2E_HEADLESS_BET=1               # vitest: test:integration:predict:headless
# E2E_HEADLESS_BROKER_WAIT_MS=90000
# E2E_HEADLESS_BETS_POLL_MS=120000

# --- Multi-wallet stress (see test/prediction/scripts/README.md § Multi-wallet stress) ---
# Copy test/prediction/fixtures/stress-wallets.example.json → stress-wallets.json (gitignored)
#
# Presets:
#   pnpm predict:place-stress-dry-run       # config check only
#   pnpm predict:place-stress-smoke           # 1 wallet, place only
#   pnpm predict:place-stress-smoke-fill      # 1 wallet, place + fill timing
#   pnpm predict:place-stress-ramp            # 1→2→4→8 + fill timing + 30s cooldown
#   pnpm predict:place-stress-timing-max      # 8 parallel + fill timing, no cooldown
#   pnpm predict:place-stress-hammer-smoke    # 1×8 place only
#   pnpm predict:place-stress-hammer          # 10×8 place only (no fill poll)
#
# E2E_STRESS_WALLETS_FILE=test/prediction/fixtures/stress-wallets.json
# E2E_STRESS_PHASES=1,2,4,8
# E2E_STRESS_COOLDOWN_MS=30000
# E2E_STRESS_BROKER_WAIT_MS=120000
# E2E_STRESS_PLACE_ONLY=1
# E2E_STRESS_HAMMER=1
# E2E_STRESS_ROUNDS=10
# E2E_STRESS_PARALLEL=8
# E2E_STRESS_DRY_RUN=1
# E2E_STRESS_BET_START_USD=1.01
# E2E_STRESS_BET_STEP_USD=0.01
# E2E_STRESS_BET_USDS=1.01,1.02
# E2E_STRESS_DEPOSIT_ALL=1
