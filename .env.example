# Copy to `.env` or `.env.local` (gitignored). Integration vars: see `test/README.md` and `test/integration/setup.ts`.
# Precedence for integration: variables already in the shell (`export`) win; then `.env.local` overrides `.env`.

# Your testnet trader secret key (Bech32, same as `sui keytool export`, usually starts with suiprivkey).
# Use either this or repo-root `.integration-trader.keystore`; if both exist, this variable wins.
# WATERX_INTEGRATION_PRIVATE_KEY=suiprivkey1qxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the reference UserAccount object id for e2e + integration (see INTEGRATION_REFERENCE_USER_ACCOUNT_ID in test/helpers/integration-reference-wallet.ts).
# WATERX_INTEGRATION_ACCOUNT_ID=0xbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb

# Optional: BTC market `position_id` (u64) for `trader-close-position` integration test when auto-scan does not find your position.
# WATERX_INTEGRATION_BTC_POSITION_ID=42

# Optional: floor (ms) between integration retries on err_cooldown_not_elapsed. Actual delay is max(this, on-chain cooldown+500) when tests pass cooldownMarketIds (see test/integration/setup.ts).
# WATERX_INTEGRATION_TRADING_STEP_MS=3000

# Optional: run only selected bases in integration lifecycle test (`test:integration:lifecycle`).
# Comma-separated BaseAsset values. Example:
# WATERX_INTEGRATION_BASES=BTC,ETH

# Optional: when the keystore has multiple keys, pick the signer by Sui address (must own the UserAccount above).
# WATERX_INTEGRATION_ADDRESS=0xaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa

# Without WATERX_INTEGRATION_PRIVATE_KEY you may use repo-root `.integration-trader.keystore` instead
# (JSON string array like Sui CLI / .admin.keystore; do not commit that file).
