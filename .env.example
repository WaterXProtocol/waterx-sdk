# =============================================================================
# WaterX SDK — local configuration (NO secrets in git)
# =============================================================================
#
# Recommended workflow:
#   1. `pnpm env:init`   → copies this file to `.env.local` (gitignored, chmod 600 on Unix)
#   2. Edit `.env.local` with real values (especially private keys).
#
# Precedence:
#   • Variables already exported in your shell always win.
#   • Then `.env` is applied (dotenv: does not override shell).
#   • Then `.env.local` fills keys that were NOT in the shell when Node started — so it can
#     override values from `.env` for machine-specific secrets without committing them.
#
# Docs: `test/README.md`, `test/integration/setup.ts`
# =============================================================================

# --- Integration trader (on-chain tests: `pnpm test:integration`) --------------

# Bech32 secret (`suiprivkey...`). Prefer `.env.local` over committing `.env`.
# Alternative: repo-root `.integration-trader.keystore` (also gitignored); env wins if both exist.
# WATERX_INTEGRATION_PRIVATE_KEY=suiprivkey1qxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: wxa account UUID when the signer owns several (`getAccountsByOwner`).
# WATERX_INTEGRATION_ACCOUNT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Optional: choose key when `.integration-trader.keystore` has multiple entries.
# WATERX_INTEGRATION_ADDRESS=0xaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa

# Optional: destructive close-one test (`trader-close-position`) — see test file.
# WATERX_INTEGRATION_CLOSE_ONE_POSITION=1

# Optional: pin ticker / position id for close integration helpers.
# WATERX_INTEGRATION_CLOSE_BASE=BTCUSD
# WATERX_INTEGRATION_POSITION_ID=42
# WATERX_INTEGRATION_BTC_POSITION_ID=42

# Optional: integration cooldown retry floor (ms); see test/integration/setup.ts.
# WATERX_INTEGRATION_TRADING_STEP_MS=3000

# Optional: subset of lifecycle bases (`pnpm test:integration:lifecycle`).
# WATERX_INTEGRATION_BASES=BTC,ETH

# Optional: Vitest parallel forks for integration (default 1).
# WATERX_INTEGRATION_MAX_FORKS=2

# Optional: explicit integration network if not passing `--testnet` / `--mainnet` on CLI.
# WATERX_INTEGRATION_NETWORK=testnet

# Opt-in lifecycle smoke path — see trader-position-lifecycle.test.ts.
# WATERX_INTEGRATION_APPROX_PRICE_CHAIN=1

# --- Simulate / e2e (`pnpm test:e2e`, `scripts/run-e2e.ts`) --------------------

# WATERX_E2E_NETWORK=testnet

# Optional full-node / paid RPC (shared by simulate + integration client init paths).
# WATERX_E2E_GRPC_URL=https://...

# WATERX_E2E_GRPC_RETRY_ATTEMPTS=8

# Parallel simulate **files** — only raise with tolerant RPC (see vitest.config.ts).
# WATERX_E2E_MAX_FORKS=3

# Discovery gates — see test/helpers/e2e/discover-on-chain-position.ts.
# WATERX_E2E_PROBE_MIN_ACCOUNT_USDC=20000000
# WATERX_E2E_DISCOVERY_MAX_LEVERAGE_UTIL_PCT=...
# WATERX_E2E_DISCOVERY_LAST_TIER_LEVERAGE_PCT=...
# WATERX_E2E_DISCOVERY_MAX_PAGES=...
# WATERX_E2E_DISCOVERY_MIN_POSITION_SIZE=...
# WATERX_E2E_DISCOVERY_PROBE_PARALLEL=1
# WATERX_E2E_DISCOVERY_PROBE_CONCURRENCY=...
# WATERX_E2E_DISCOVERY_MAX_USDC_COIN_PROBES=...
# Optional wxa account for simulate discovery (usually same as integration account after persistent-state).
# WATERX_E2E_WXA_ACCOUNT_ID=0x...
# WATERX_E2E_WALLET_USDC_OWNER=0x...
# WATERX_E2E_WLP_REDEEM_OWNER=0x...

# Dump simulate successes — scratch helper / debugging.
# WATERX_E2E_SIMULATE_SUCCESS_DUMP=1

# Hermes REST (oracle price VAAs): testnet default is beta; on **429/503** the SDK retries and
# auto-fails over **beta ⇄ prod** (`hermes-beta.pyth.network` ↔ `hermes.pyth.network`).
# GitHub PR CI pins prod (`WATERX_PYTH_HERMES_URL`) for flake-free e2e — copy to `.env.local` locally if needed.
WATERX_PYTH_HERMES_URL=https://hermes.pyth.network
# WATERX_PYTH_HERMES_FALLBACK_URL=https://custom-hermes.example
# WATERX_PYTH_HERMES_MAX_RETRIES=8

# --- Misc -----------------------------------------------------------------------

# Override canonical config URL (advanced).
# WATERX_CONFIG_URL=https://...
