{
  "name": "@waterx/perp-sdk",
  "version": "1.0.2",
  "description": "WaterX Perpetual Protocol SDK",
  "license": "MIT",
  "author": "WaterX",
  "repository": {
    "type": "git",
    "url": "https://github.com/WaterXProtocol/waterx-sdk"
  },
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && tsc-alias",
    "codegen": "cd waterx-contracts/waterx_perp && sui move summary && cd ../bucket_framework && sui move summary && cd ../bucket_oracle && sui move summary && cd ../reward_distributor && sui move summary && cd ../pyth_sponsor_rule && sui move summary && cd ../.. && npx sui-ts-codegen generate && tsx scripts/fix-generated-imports.ts",
    "test": "vitest run --project unit --project e2e",
    "test:unit": "vitest run --project unit",
    "test:e2e": "vitest run --project e2e",
    "test:integration": "vitest run --project integration-trader",
    "test:integration:lifecycle": "vitest run --project integration-trader test/integration/user/trader-position-lifecycle.test.ts",
    "test:integration:market-config": "vitest run --project integration-trader test/integration/user/trader-market-onchain-config.test.ts",
    "test:integration:persistent-state": "vitest run --project integration-trader test/integration/user/trader-e2e-persistent-state.test.ts",
    "test:all": "vitest run",
    "test:watch": "vitest --project unit --project e2e",
    "test:coverage": "vitest run --project unit --project e2e --coverage",
    "test:ci:unit": "vitest run --project unit --coverage --reporter=verbose --reporter=junit --outputFile=test-results-unit.xml",
    "test:ci:simulate": "vitest run --project e2e --reporter=verbose --reporter=junit --outputFile=test-results-simulate.xml",
    "test:ci:e2e": "tsx scripts/e2e-preflight.ts --allow-oracle-transient --allow-missing-positions --allow-missing-tto-split && pnpm test:ci:simulate",
    "test:ci:e2e:coverage": "tsx scripts/e2e-preflight.ts --allow-oracle-transient --allow-missing-positions --allow-missing-tto-split && pnpm test:e2e -- --coverage",
    "test:ci:full": "pnpm test:ci:unit && pnpm test:ci:e2e",
    "test:ci": "pnpm test:ci:full",
    "diagnose:positions": "tsx scripts/diagnose-integration-positions.ts",
    "oracle:aggregates": "tsx scripts/print-oracle-aggregates.ts",
    "query-output": "tsx scripts/query-output.ts",
    "e2e:preflight": "tsx scripts/e2e-preflight.ts",
    "e2e:prepare": "tsx scripts/e2e-prepare.ts",
    "e2e:ci": "((pnpm e2e:preflight -- --allow-oracle-transient --allow-missing-wlp) || (pnpm e2e:prepare && pnpm e2e:preflight -- --allow-oracle-transient)) && pnpm test:e2e",
    "create-testnet-account": "tsx scripts/create-testnet-user-account.ts",
    "rewarder:smoke": "tsx scripts/reward-distributor-smoke.ts",
    "close-all-btc": "tsx scripts/close-all-my-btc-positions.ts",
    "e2e:bootstrap-positions": "tsx scripts/bootstrap-e2e-lifecycle-positions.ts",
    "lint": "pnpm lint:eslint && pnpm lint:prettier",
    "lint:eslint": "eslint \"src/**/*.ts\" \"test/**/*.ts\" \"scripts/**/*.ts\"",
    "lint:prettier": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\" \"scripts/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"test/**/*.ts\" \"scripts/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"scripts/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mysten/bcs": "^1.9.2",
    "@mysten/sui": "^2.9.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@mysten/codegen": "^0.8.3",
    "@types/node": "^24.12.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^3.2.4",
    "dotenv": "^17.4.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@9.15.0"
}
