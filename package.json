{
  "name": "@waterx/perp-sdk",
  "version": "1.1.1-dev.0",
  "description": "WaterX Perpetual Protocol SDK",
  "license": "MIT",
  "author": "WaterX",
  "repository": {
    "type": "git",
    "url": "https://github.com/WaterXProtocol/waterx-sdk.git"
  },
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && tsc-alias",
    "codegen": "tsx scripts/codegen-summaries.ts && npx sui-ts-codegen generate && tsx scripts/fix-generated-imports.ts",
    "lint": "pnpm lint:eslint && pnpm lint:prettier",
    "lint:eslint": "eslint \"src/**/*.ts\" \"test/**/*.ts\" \"scripts/**/*.ts\"",
    "lint:prettier": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\" \"scripts/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"test/**/*.ts\" \"scripts/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"scripts/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --project unit --project e2e",
    "test:unit": "vitest run --project unit",
    "test:e2e": "tsx scripts/run-e2e.ts",
    "test:e2e:testnet": "tsx scripts/run-e2e.ts --testnet",
    "test:e2e:mainnet": "tsx scripts/run-e2e.ts --mainnet",
    "test:e2e:parallel": "WATERX_E2E_MAX_FORKS=3 tsx scripts/run-e2e.ts",
    "test:integration": "vitest run --project integration-trader",
    "test:integration:lifecycle": "vitest run --project integration-trader test/integration/user/trader-position-lifecycle.test.ts",
    "test:integration:market-config": "vitest run --project integration-trader test/integration/user/trader-market-onchain-config.test.ts",
    "test:integration:persistent-state": "vitest run --project integration-trader test/integration/user/trader-e2e-persistent-state.test.ts",
    "test:all": "vitest run",
    "test:watch": "vitest --project unit --project e2e",
    "test:coverage": "vitest run --project unit --project e2e --coverage",
    "test:ci:unit": "vitest run --project unit --coverage --reporter=dot --reporter=junit --outputFile=test-results-unit.xml",
    "test:ci:e2e": "tsx scripts/run-e2e.ts --reporter=dot --reporter=junit --outputFile=test-results-simulate.xml",
    "test:ci:e2e:testnet": "tsx scripts/run-e2e.ts --testnet --reporter=dot --reporter=junit --outputFile=test-results-simulate-testnet.xml",
    "test:ci:e2e:mainnet": "tsx scripts/run-e2e.ts --mainnet --reporter=dot --reporter=junit --outputFile=test-results-simulate-mainnet.xml",
    "test:ci:e2e:coverage": "tsx scripts/run-e2e.ts --coverage",
    "test:ci:full": "pnpm test:ci:unit && pnpm test:ci:e2e",
    "test:ci": "pnpm test:ci:full"
  },
  "dependencies": {
    "@mysten/bcs": "^1.9.2",
    "@mysten/sui": "^2.9.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@mysten/codegen": "^0.8.3",
    "@types/node": "^24.12.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "@vitest/coverage-v8": "^3.2.4",
    "dotenv": "^17.4.0",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@9.15.0"
}
