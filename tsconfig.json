{
  "extends": "./tsconfig.build.json",
  "compilerOptions": {
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": false,
    "rootDirs": ["src", "test", "tests", "scripts", "examples"],
    "paths": {
      "@waterx/perp-sdk": ["./src/index.ts"],
      "~predict/*": ["./src/prediction/*"],
      "~predict-scripts/*": ["./test/prediction/scripts/*"],
      "~predict-tests/*": ["./test/prediction/*"]
    }
  },
  "include": [
    "src",
    "scripts",
    "examples",
    "test/prediction",
    "test/perp/unit",
    "test/perp/e2e",
    "test/perp/helpers/fixtures",
    "test/perp/helpers/test-client.ts",
    "test/perp/helpers/e2e/e2e-client.ts",
    "test/perp/helpers/e2e/e2e-setup.ts",
    "test/perp/helpers/e2e/transient-rpc.ts",
    "test/perp/helpers/trading/expected-open-trading-fee.ts"
  ],
  "exclude": ["node_modules", "**/__tests__/*", "test/prediction/helpers/bucket-backend-mono"]
}
