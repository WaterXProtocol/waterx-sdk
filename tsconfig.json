{
  "extends": "./tsconfig.build.json",
  "compilerOptions": {
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": false,
    "rootDirs": ["src", "test", "scripts", "examples"],
    "paths": {
      "@waterx/perp-sdk": ["./src/index.ts"]
    }
  },
  "include": [
    "src",
    "scripts",
    "examples",
    "test/unit",
    "test/simulate",
    "test/integration",
    "test/helpers/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "**/__tests__/*",
    "test/helpers/trading/simulate-resize-size.ts",
    "test/helpers/trading/above-max-leverage-case.ts",
    "test/helpers/e2e/e2e-open-sizing-expect.ts",
    "test/helpers/e2e/wlp-mint-simulate-tx.ts",
    "test/helpers/trading/market-summary-assertions.ts"
  ]
}
