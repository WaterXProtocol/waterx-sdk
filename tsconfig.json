{
  "extends": "./tsconfig.build.json",
  "compilerOptions": {
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": false,
    "rootDirs": ["src", "test", "scripts", "examples"],
    "paths": {
      "@waterx/sdk": ["./src/index.ts"]
    }
  },
  "include": [
    "src",
    "scripts",
    "examples",
    "test/unit",
    "test/simulate",
    "test/helpers/fixtures",
    "test/helpers/test-client.ts",
    "test/helpers/e2e/e2e-client.ts",
    "test/helpers/e2e/e2e-setup.ts",
    "test/helpers/e2e/transient-rpc.ts",
    "test/helpers/trading/expected-open-trading-fee.ts"
  ],
  "exclude": ["node_modules", "**/__tests__/*"]
}
