# Optional — most settings live in config/stress.config.json
# Shell-exported vars override both .env and JSON.

# Chain RPC (optional; default uses waterx-config testnet)
# E2E_GRPC_URL=https://your-fullnode.example.com

# Deposit bootstrap (base units, 6 decimals — default 1000000 = $1)
# SEED_DEPOSIT_AMOUNT=1000000
# E2E_STRESS_DEPOSIT_ALL=1

# One-off overrides (usually use --profile or edit stress.config.json)
# E2E_STRESS_PHASES=1,2,4
# E2E_STRESS_COOLDOWN_MS=0
# E2E_STRESS_ROUNDS=5
